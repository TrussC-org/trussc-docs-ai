# systemd unit for the TrussC trussc-docs-ai API. This is a TEMPLATE — adjust:
#   User=             the service user
#   WorkingDirectory= where you installed the project
#   ExecStart=        path to node (/usr/bin/node for a system install; for nvm use
#                     the absolute path, e.g. /home/<user>/.nvm/versions/node/<ver>/bin/node)
#   STATS_SALT=       add a real secret in prod so hashed IPs can't be correlated
#                     (e.g. `openssl rand -hex 16`). Omitted here on purpose.
# Install: sudo cp deploy/trussc-docs-ai.service /etc/systemd/system/
#          sudo systemctl daemon-reload && sudo systemctl enable --now trussc-docs-ai
[Unit]
Description=TrussC trussc-docs-ai RAG API
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=trussc
WorkingDirectory=/opt/trussc-docs-ai
ExecStart=/usr/bin/node server.mjs
Environment=PORT=8788
Environment=OLLAMA_URL=http://127.0.0.1:11434
Environment=GEN_MODEL=qwen3.5:4b
Environment=EMBED_MODEL=bge-m3
Environment=NUM_CTX=24000
# 4B (~3.6GB) + bge-m3 (~0.7GB) both fit the 8GB A1000 on GPU with headroom, so
# embeddings stay on GPU (fast). Set EMBED_ON_CPU=1 only if VRAM gets tight.
Environment=REF_BASE=https://trussc.org
Environment=ALLOW_ORIGIN=https://trussc.org
# Per-IP rate limit (behind the tunnel the real IP is in cf-connecting-ip).
Environment=RATE_MAX=15
Environment=RATE_WIN=60000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
